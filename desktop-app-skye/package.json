{
  "name": "skye",
  "productName": "Skye",
  "version": "1.0.0",
  "description": "A talking sky clock with a stopwatch, timer, and calculator.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "package:win": "electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.chimes.skye",
    "productName": "Skye",
    "copyright": "",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "app/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "artifactName": "Skye-Setup.exe",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Skye"
    }
  }
}
