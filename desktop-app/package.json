{
  "name": "snake",
  "productName": "Snake",
  "version": "1.0.0",
  "description": "A Nokia-phone-styled Snake game.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "package:win": "electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.chimes.snake",
    "productName": "Snake",
    "copyright": "",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "app/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "artifactName": "Snake-Setup.exe",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Snake"
    }
  }
}
